# LokMate Environment Variables
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the `.env` file to version control.

# --------------------------------------------------------------------------
# Google Gemini API
# Obtain your key from: https://aistudio.google.com/app/apikey
# --------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------------------------------------
# FastAPI Application Settings
# --------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Uvicorn server host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# --------------------------------------------------------------------------
# Edge / Offline Model Settings (future integration)
# Set USE_LOCAL_MODEL=true to route STT/translation to an on-device model
# --------------------------------------------------------------------------
USE_LOCAL_MODEL=false
LOCAL_MODEL_PATH=./local_models/whisper-small-quantized
